{
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Bash(cd*)",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(cat*)",
      "Bash(grep*)",
      "Bash(find*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git add* && git commit*)",
      "Bash(git checkout*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git push* && gh pr create*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh pr create*)",
      "Bash(terraform fmt*)",
      "Bash(terraform plan*)"
    ],
    "deny": [
      "Bash(sudo*)",
      "Bash(rm -rf*)",
      "Read(.env)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Write(.env)",
      "Bash(curl*)"
    ]
  }
}
